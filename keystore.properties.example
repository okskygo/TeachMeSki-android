# Copy this file to `keystore.properties` (which is gitignored) and fill in real values.
# See SIGNING.md for how to generate the keystore itself.
#
# storeFile can be absolute OR relative to teachmeski-android/.
# Recommended: keep the .jks OUTSIDE the repo (e.g. ~/.teachmeski-keystore/upload.jks).

storeFile=/Users/YOU/.teachmeski-keystore/upload.jks
storePassword=CHANGE_ME
keyAlias=teachmeski-upload
keyPassword=CHANGE_ME
